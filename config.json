    "社交": ["WeChatAppEx.exe", "QQ.exe", "Telegram.exe", "Discord.exe", "WhatsApp.exe"],
    "娱乐": ["chrome.exe", "msedge.exe", "Spotify.exe", "Steam.exe", "EpicGamesLauncher.exe"],
    "开发": ["Code.exe", "code.exe", "python.exe", "node.exe", "git.exe", "Docker Desktop.exe"],
    "系统": ["explorer.exe", "System Idle Process", "csrss.exe", "services.exe", "lsass.exe"]
